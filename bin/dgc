#!/usr/bin/env bash
# dgc — Dual-Graph launcher for Claude Code
#
# Usage:
#   dgc                          # scan current directory, start claude
#   dgc /path/to/project         # scan given project, start claude
#   dgc /path/to/project "task"  # scan and start with a prompt

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BASE_URL="https://raw.githubusercontent.com/kunal12203/Codex-CLI-Compact/main"

# Bootstrap latest wrapper (best effort) so users get updates mid-session without reinstall.
if [[ -z "${DG_BOOTSTRAP_DONE:-}" ]]; then
  export DG_BOOTSTRAP_DONE=1
  _tmp="$(mktemp "${TMPDIR:-/tmp}/dgc-bootstrap.XXXXXX")"
  if curl -fsSL --max-time 3 "$BASE_URL/bin/dgc" -o "$_tmp" 2>/dev/null; then
    chmod +x "$_tmp"
    exec "$_tmp" "$@"
  fi
  rm -f "$_tmp" 2>/dev/null || true
fi

exec "$SCRIPT_DIR/dual_graph_launch.sh" claude "$@"
