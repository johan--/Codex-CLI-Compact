#!/usr/bin/env python3
"""Codex A/B benchmark logger for dashboard live monitor.

Logs session rows to ~/.dual-graph/bench_log.jsonl in the same shape used by server.py.
Supports:
  - run codex (without graph) and auto-log tokens/prompts
  - run dg (with graph) and auto-log tokens/prompts
  - save latest existing session by project path
  - report aggregate totals
"""

from __future__ import annotations

import argparse
import json
import subprocess
import sys
import time
from dataclasses import dataclass
from datetime import datetime, timezone
from pathlib import Path
from typing import Iterable


HOME = Path.home()
CODEX_SESSIONS = HOME / ".codex" / "sessions"
BENCH_LOG = HOME / ".dual-graph" / "bench_log.jsonl"
SCRIPT_DIR = Path(__file__).resolve().parent
DG_LAUNCHER = SCRIPT_DIR / "dg"


@dataclass
class SessionData:
    file: Path
    cwd: str
    ts_file: float
    total_tokens: int
    input_tokens: int
    output_tokens: int
    prompts: list[str]


def _iter_session_files() -> Iterable[Path]:
    if not CODEX_SESSIONS.exists():
        return []
    files = [p for p in CODEX_SESSIONS.rglob("*.jsonl") if p.is_file()]
    files.sort(key=lambda p: p.stat().st_mtime, reverse=True)
    return files


def _parse_session(path: Path) -> SessionData | None:
    cwd = ""
    prompts: list[str] = []
    total_tokens = 0
    input_tokens = 0
    output_tokens = 0
    try:
        for raw in path.read_text(encoding="utf-8", errors="ignore").splitlines():
            if not raw.strip():
                continue
            try:
                obj = json.loads(raw)
            except json.JSONDecodeError:
                continue

            typ = obj.get("type")
            payload = obj.get("payload", {}) if isinstance(obj, dict) else {}

            if typ == "session_meta":
                meta = payload if isinstance(payload, dict) else {}
                cwd = str(meta.get("cwd", cwd))
                continue

            if typ == "response_item":
                item = payload if isinstance(payload, dict) else {}
                if item.get("type") == "message" and item.get("role") == "user":
                    for c in item.get("content", []) or []:
                        text = c.get("text") if isinstance(c, dict) else ""
                        if isinstance(text, str) and text.strip():
                            prompts.append(text.strip())
                continue

            if typ == "event_msg":
                msg = payload if isinstance(payload, dict) else {}
                if msg.get("type") != "token_count":
                    continue
                info = msg.get("info", {}) if isinstance(msg.get("info"), dict) else {}
                usage = info.get("total_token_usage", {}) if isinstance(info.get("total_token_usage"), dict) else {}
                t = int(usage.get("total_tokens", 0) or 0)
                if t >= total_tokens:
                    total_tokens = t
                    # count cached input in "inp" so dashboard inp/out columns represent true billed context size
                    input_tokens = int(usage.get("input_tokens", 0) or 0) + int(usage.get("cached_input_tokens", 0) or 0)
                    output_tokens = int(usage.get("output_tokens", 0) or 0)
    except OSError:
        return None

    if not cwd and total_tokens <= 0 and not prompts:
        return None
    return SessionData(
        file=path,
        cwd=cwd,
        ts_file=path.stat().st_mtime,
        total_tokens=total_tokens,
        input_tokens=input_tokens,
        output_tokens=output_tokens,
        prompts=prompts,
    )


def _find_latest_session(project: Path, after_ts: float = 0.0) -> SessionData | None:
    target = str(project.resolve())
    for f in _iter_session_files():
        if f.stat().st_mtime < after_ts:
            continue
        session = _parse_session(f)
        if session is None:
            continue
        # Match exact cwd; fallback to suffix containment for path casing quirks.
        if session.cwd == target or target.endswith(session.cwd) or session.cwd.endswith(target):
            return session
    return None


def _append_bench_entry(entry: dict) -> None:
    BENCH_LOG.parent.mkdir(parents=True, exist_ok=True)
    with BENCH_LOG.open("a", encoding="utf-8") as fh:
        fh.write(json.dumps(entry, ensure_ascii=True) + "\n")


def _log_session(project: Path, label: str, session: SessionData, runner: str) -> dict:
    entry = {
        "ts": datetime.now(timezone.utc).isoformat(),
        "mode": "session",
        "runner": runner,
        "label": label,
        "project": str(project.resolve()),
        "tokens": int(session.total_tokens),
        "inp": int(session.input_tokens),
        "out": int(session.output_tokens),
        "prompts": session.prompts[:40],
        "session_file": str(session.file),
    }
    _append_bench_entry(entry)
    return entry


def _run_mode(project: Path, label: str, mode: str, prompt: str) -> int:
    start_ts = time.time()
    if mode == "codex":
        cmd = ["codex", "-C", str(project)]
        if prompt:
            cmd.append(prompt)
        runner = "codex"
    elif mode == "dg":
        cmd = [str(DG_LAUNCHER), str(project)]
        if prompt:
            cmd.append(prompt)
        runner = "dg"
    else:
        print(f"Unsupported mode: {mode}", file=sys.stderr)
        return 2

    rc = subprocess.call(cmd)
    session = _find_latest_session(project, after_ts=start_ts - 2.0)
    if session is None:
        print("[dg-bench] No codex session found to log.", file=sys.stderr)
        return rc if rc != 0 else 1
    entry = _log_session(project, label, session, runner)
    print(
        "[dg-bench] Logged session:"
        f" label={entry['label']} tokens={entry['tokens']} inp={entry['inp']} out={entry['out']}"
    )
    return rc


def _save_mode(project: Path, label: str) -> int:
    session = _find_latest_session(project)
    if session is None:
        print("[dg-bench] No matching codex session found.", file=sys.stderr)
        return 1
    entry = _log_session(project, label, session, "save")
    print(
        "[dg-bench] Saved latest session:"
        f" label={entry['label']} tokens={entry['tokens']} inp={entry['inp']} out={entry['out']}"
    )
    return 0


def _report_mode() -> int:
    if not BENCH_LOG.exists():
        print("[dg-bench] No bench log yet.")
        return 0

    entries = []
    for raw in BENCH_LOG.read_text(encoding="utf-8", errors="ignore").splitlines():
        if not raw.strip():
            continue
        try:
            e = json.loads(raw)
        except json.JSONDecodeError:
            continue
        if e.get("mode") == "session":
            entries.append(e)

    with_total = 0
    without_total = 0
    for e in entries:
        label = str(e.get("label", "")).lower()
        tok = int(e.get("tokens", 0) or 0)
        if "without" in label:
            without_total += tok
        elif "with" in label:
            with_total += tok

    saved = without_total - with_total
    pct = (saved * 100 / without_total) if without_total else 0.0
    print(f"[dg-bench] Session rows: {len(entries)}")
    print(f"[dg-bench] with-graph tokens   : {with_total}")
    print(f"[dg-bench] without-graph tokens: {without_total}")
    print(f"[dg-bench] saved               : {saved} ({pct:.1f}%)")
    print(f"[dg-bench] log                 : {BENCH_LOG}")
    return 0


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(description="Codex vs DG benchmark logger for dashboard.")
    p.add_argument("--project", default=str(Path.cwd()), help="Project directory for session matching.")
    p.add_argument(
        "--label",
        default="with-graph",
        help="Session label (use 'with-graph' or 'without-graph' so dashboard aggregates correctly).",
    )
    p.add_argument("--mode", choices=["codex", "dg"], help="Run mode to launch and then auto-log.")
    p.add_argument("--prompt", default="", help="Optional starting prompt for run mode.")
    p.add_argument("--save", action="store_true", help="Log latest matching existing session for project.")
    p.add_argument("--report", action="store_true", help="Show aggregate totals from bench log.")
    return p


def main() -> int:
    args = build_parser().parse_args()
    project = Path(args.project).resolve()

    if args.report:
        return _report_mode()
    if args.save:
        return _save_mode(project, args.label)
    if args.mode:
        return _run_mode(project, args.label, args.mode, args.prompt)

    print("Choose one: --report, --save, or --mode {codex|dg}", file=sys.stderr)
    return 2


if __name__ == "__main__":
    raise SystemExit(main())
