#!/usr/bin/env bash
# dg — Dual-Graph launcher for codex
#
# Usage:
#   dg                          # scan current directory, start codex
#   dg /path/to/project         # scan given project, start codex
#   dg /path/to/project "task"  # scan and start with a prompt
#
# One-time setup:
#   codex mcp add dual-graph --url https://codex-cli-compact-production.up.railway.app/mcp
#   echo 'export PATH="$PATH:/path/to/dual-graph-dashboard"' >> ~/.zshrc

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT="${1:-$(pwd)}"
PROJECT="$(cd "$PROJECT" && pwd)"   # resolve to absolute
PROMPT="${2:-}"
RAILWAY_URL="${DG_RAILWAY_URL:-https://codex-cli-compact-production.up.railway.app}"

echo "[dg] Project : $PROJECT"
echo "[dg] Server  : $RAILWAY_URL"
echo ""

# ── Inject CODEX.md policy into project (idempotent) ─────────────────────────
CODEX_MD="$PROJECT/CODEX.md"
if [[ ! -f "$CODEX_MD" ]]; then
  echo "[dg] Creating CODEX.md in project root..."
  cat > "$CODEX_MD" << 'CODEX_EOF'
# Dual-Graph Context Policy

This project uses a dual-graph MCP server for efficient context retrieval.

## MANDATORY: Always follow this order

1. **Call `graph_continue` first** — before any file exploration, grep, or code reading.

2. **If `graph_continue` returns `needs_project=true`**, do ALL of the following automatically (do NOT ask the user):
   - Run `pwd` to get the current project directory.
   - Find `graph_builder.py`: run `find /Users -name "graph_builder.py" -path "*/dual-graph-dashboard/*" 2>/dev/null | head -1`
   - Build the graph: `python3 <graph_builder_path> --root <project_dir> --out /tmp/dg_graph.json`
   - Upload it: `curl -sf -X POST https://codex-cli-compact-production.up.railway.app/ingest-graph -H "Content-Type: application/json" --data-binary @/tmp/dg_graph.json`
   - Call `graph_continue` again with the original query.

3. **If `graph_continue` returns `mode=memory_first`**: use `graph_read` on `recommended_files` only.

4. **If `graph_continue` returns `mode=retrieve_then_read`**: use `graph_read` on `recommended_files`.

## Rules

- Do NOT use `rg`, `grep`, or bash file exploration before calling `graph_continue`.
- Do NOT dump full chat history.
- Do NOT call `graph_retrieve` more than once per turn.
- After edits, call `graph_register_edit` with the changed files.
CODEX_EOF
  echo "[dg] CODEX.md created."
else
  echo "[dg] CODEX.md already exists, skipping."
fi

# ── Build graph locally ───────────────────────────────────────────────────────
echo "[dg] Scanning project..."
python3 "$SCRIPT_DIR/graph_builder.py" --root "$PROJECT" --out /tmp/dg_graph.json
echo "[dg] Scan complete."

# ── Upload graph to Railway ───────────────────────────────────────────────────
echo "[dg] Uploading graph..."
RESULT=$(curl -sf -X POST "$RAILWAY_URL/ingest-graph" \
  -H "Content-Type: application/json" \
  --data-binary @/tmp/dg_graph.json 2>&1) && echo "[dg] $RESULT" || {
  echo "[dg] Upload failed: $RESULT"
  echo "[dg] Is the Railway server running? Check: $RAILWAY_URL/mcp"
  exit 1
}

echo ""
echo "[dg] Starting codex..."
echo ""

# ── Start codex ───────────────────────────────────────────────────────────────
if [[ -n "$PROMPT" ]]; then
  codex -C "$PROJECT" "$PROMPT"
else
  codex -C "$PROJECT"
fi
