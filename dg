#!/usr/bin/env bash
# dg — Dual-Graph launcher for codex (fully local, no cloud needed)
#
# Usage:
#   dg                          # scan current directory, start codex
#   dg /path/to/project         # scan given project, start codex
#   dg /path/to/project "task"  # scan and start with a prompt
#
# One-time setup:
#   echo 'export PATH="$PATH:/path/to/dual-graph-dashboard"' >> ~/.zshrc && source ~/.zshrc
#   pip install fastmcp uvicorn anyio starlette
#   codex mcp add dual-graph --url http://localhost:8080/mcp

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT="${1:-$(pwd)}"
PROJECT="$(cd "$PROJECT" && pwd)"   # resolve to absolute
PROMPT="${2:-}"

DASH_PORT=8787
MCP_PORT=8080

echo "[dg] Project : $PROJECT"
echo "[dg] MCP     : http://localhost:$MCP_PORT/mcp"
echo ""

# ── Inject CODEX.md policy into project (idempotent) ─────────────────────────
CODEX_MD="$PROJECT/CODEX.md"
if [[ ! -f "$CODEX_MD" ]]; then
  echo "[dg] Creating CODEX.md in project root..."
  cat > "$CODEX_MD" << 'CODEX_EOF'
# Dual-Graph Context Policy

This project uses a dual-graph MCP server for efficient context retrieval.

## MANDATORY: Always follow this order

1. **Call `graph_continue` first** — before any file exploration, grep, or code reading.

2. **If `graph_continue` returns `needs_project=true`**, call `graph_scan` with the current
   project directory (run `pwd` if unsure of the path). Do NOT ask the user — do it automatically.

3. **If `graph_continue` returns `mode=memory_first`**: use `graph_read` on `recommended_files` only.

4. **If `graph_continue` returns `mode=retrieve_then_read`**: use `graph_read` on `recommended_files`.

## Rules

- Do NOT use `rg`, `grep`, or bash file exploration before calling `graph_continue`.
- Do NOT dump full chat history.
- Do NOT call `graph_retrieve` more than once per turn.
- After edits, call `graph_register_edit` with the changed files.
CODEX_EOF
  echo "[dg] CODEX.md created."
else
  echo "[dg] CODEX.md already exists, skipping."
fi

# ── Scan project → local info graph ──────────────────────────────────────────
echo "[dg] Scanning project..."
mkdir -p "$SCRIPT_DIR/data"
python3 "$SCRIPT_DIR/graph_builder.py" \
  --root "$PROJECT" \
  --out "$SCRIPT_DIR/data/info_graph.json"
echo "[dg] Scan complete."
echo ""

# ── Start dashboard API (internal, port 8787) ─────────────────────────────────
echo "[dg] Starting local servers..."
DUAL_GRAPH_PROJECT_ROOT="$PROJECT" PORT=$DASH_PORT \
  python3 "$SCRIPT_DIR/server.py" &
DASH_PID=$!

# Wait for dashboard (up to 15s)
for i in $(seq 1 15); do
  if python3 - 2>/dev/null <<PY
import urllib.request, sys
try:
    urllib.request.urlopen("http://127.0.0.1:$DASH_PORT/healthz", timeout=2)
    sys.exit(0)
except Exception:
    sys.exit(1)
PY
  then
    break
  fi
  sleep 1
done

# ── Start MCP server (public, port 8080) ──────────────────────────────────────
DG_BASE_URL="http://127.0.0.1:$DASH_PORT" \
DUAL_GRAPH_PROJECT_ROOT="$PROJECT" \
PORT=$MCP_PORT \
  python3 "$SCRIPT_DIR/mcp_graph_server.py" &
MCP_PID=$!

# Clean up servers when codex exits
trap 'echo ""; echo "[dg] Shutting down servers..."; kill $DASH_PID $MCP_PID 2>/dev/null; exit' INT TERM EXIT

# Brief wait for MCP to be ready
sleep 2
echo "[dg] Servers ready."
echo ""
echo "[dg] Starting codex..."
echo ""

# ── Start codex ───────────────────────────────────────────────────────────────
if [[ -n "$PROMPT" ]]; then
  codex -C "$PROJECT" "$PROMPT"
else
  codex -C "$PROJECT"
fi
