#!/usr/bin/env bash
# dgc-bench — Real token benchmarking: dual-graph vs baseline
#
# Modes:
#   dgc-bench --live /path/to/workspace
#       Interactive session: builds TWO projects side-by-side.
#       Type prompts, each runs on both with-graph/ and without-graph/.
#       Shows real tokens + quality comparison at the end.
#
#   dgc-bench /path/to/project "prompt"
#       Single task WITH graph. Logs real tokens, estimates baseline.
#
#   dgc-bench --report
#       Show cumulative analytics from all logged runs.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV="$SCRIPT_DIR/venv"
PYTHON="$VENV/bin/python3"
BENCH_LOG="$SCRIPT_DIR/bench_log.jsonl"
MCP_PORT=8080

# ── Shared helpers ────────────────────────────────────────────────────────────
_TOK_SCRIPT='
import sys, json
inp = out = 0
for line in sys.stdin:
    try:
        obj = json.loads(line.strip())
    except Exception:
        continue
    for u in [obj.get("usage"), obj.get("message", {}).get("usage")]:
        if u and isinstance(u, dict):
            inp = max(inp, int(u.get("input_tokens",  0)))
            out = max(out, int(u.get("output_tokens", 0)))
    t = obj.get("total_input_tokens", 0)
    if t: inp = max(inp, int(t))
    t = obj.get("total_output_tokens", 0)
    if t: out = max(out, int(t))
print(inp + out)
'

_tokens_from_stream() {
  # Extract total tokens from claude --output-format stream-json output
  # Uses -c so stdin is free for the pipe (heredoc would conflict)
  "$PYTHON" -c "$_TOK_SCRIPT"
}

_BENCH_STDERR="/tmp/dgc_bench_stderr.log"
_LAST_TOKENS=0

_DISPLAY_SCRIPT='
import sys, json
for line in sys.stdin:
    line = line.strip()
    if not line: continue
    try: obj = json.loads(line)
    except: continue
    if obj.get("type") == "assistant":
        for block in obj.get("message", {}).get("content", []):
            btype = block.get("type", "")
            if btype == "text":
                sys.stdout.write(block.get("text", ""))
                sys.stdout.flush()
            elif btype == "tool_use":
                name = block.get("name", "")
                inp = str(block.get("input", {}))[:80]
                sys.stdout.write("  -> " + name + "(" + inp + ")\n")
                sys.stdout.flush()
    elif obj.get("type") == "result":
        sys.stdout.write("\n")
        sys.stdout.flush()
'

_session_tokens() {
  # Read total tokens from the most recent Claude session file for a project dir
  local workdir="$1"
  "$PYTHON" - "$workdir" 2>/dev/null << 'PYEOF' || echo 0
import sys, json
from pathlib import Path
project = sys.argv[1]
encoded = project.replace('/', '-').replace(' ', '-')
sessions_dir = Path.home() / '.claude' / 'projects' / encoded
if not sessions_dir.exists():
    base = Path.home() / '.claude' / 'projects'
    match = next((d for d in base.iterdir() if d.name.lower() == encoded.lower()), None)
    sessions_dir = match if match else sessions_dir
if not sessions_dir.exists():
    print(0); exit()
files = sorted(sessions_dir.glob('*.jsonl'), key=lambda f: f.stat().st_mtime)
if not files:
    print(0); exit()
inp = out = 0
for line in open(files[-1]):
    try:
        obj = json.loads(line.strip())
        for u in [obj.get('usage'), (obj.get('message') or {}).get('usage')]:
            if isinstance(u, dict):
                inp = max(inp, u.get('input_tokens', 0) or 0)
                out = max(out, u.get('output_tokens', 0) or 0)
        inp = max(inp, obj.get('total_input_tokens', 0) or 0)
        out = max(out, obj.get('total_output_tokens', 0) or 0)
    except: pass
print(inp + out)
PYEOF
}

_run_interactive() {
  # Run claude as full TUI; read tokens from session file after exit
  local workdir="$1" label="$2"
  echo ""
  echo "  ─── $label ──────────────────────────────────────"
  echo "  Claude is starting. Answer questions, then type /exit when done."
  echo "  ─────────────────────────────────────────────────"
  echo ""
  (cd "$workdir" && claude) || true
  echo ""
  # Try to read tokens from session storage
  local tok
  tok=$(_session_tokens "$workdir")
  if [[ "$tok" -gt 0 ]]; then
    _LAST_TOKENS=$tok
  else
    printf "  Enter token count (shown in session footer, or 0 to skip): "
    read -r tok
    _LAST_TOKENS="${tok:-0}"
  fi
}

_run_headless() {
  # Stream output live to terminal; capture tokens via temp file (subshell for cd)
  local workdir="$1" prompt="$2"
  local capfile="/tmp/dgc_bench_cap_$$.jsonl"
  local tokfile="/tmp/dgc_bench_tok_$$.txt"
  (
    cd "$workdir"
    claude --output-format stream-json --verbose --print --dangerously-skip-permissions "$prompt" \
      2>"$_BENCH_STDERR" \
      | tee "$capfile" \
      | "$PYTHON" -c "$_DISPLAY_SCRIPT" || true
    "$PYTHON" -c "$_TOK_SCRIPT" < "$capfile" > "$tokfile" 2>/dev/null || echo 0 > "$tokfile"
  )
  rm -f "$capfile"
  _LAST_TOKENS=$(cat "$tokfile" 2>/dev/null || echo 0)
  rm -f "$tokfile"
}

_rebuild_graph() {
  local workdir="$1" data_dir="$2"
  mkdir -p "$data_dir"
  "$VENV/bin/python3" "$SCRIPT_DIR/graph_builder.py" \
    --root "$workdir" --out "$data_dir/info_graph.json" 2>/dev/null
}

_start_mcp_server() {
  local data_dir="$1" workdir="$2"
  if nc -z localhost $MCP_PORT 2>/dev/null; then
    # Already running — restart with new data dir
    lsof -ti:$MCP_PORT 2>/dev/null | xargs kill -9 2>/dev/null || true
    sleep 0.5
  fi
  DG_DATA_DIR="$data_dir" \
  DUAL_GRAPH_PROJECT_ROOT="$workdir" \
  DG_BASE_URL="http://localhost:$MCP_PORT" \
  PORT=$MCP_PORT \
    "$VENV/bin/python3" "$SCRIPT_DIR/mcp_graph_server.py" \
      >> "$data_dir/mcp_server.log" 2>&1 &
  MCP_PID=$!
  for i in $(seq 1 20); do
    nc -z localhost $MCP_PORT 2>/dev/null && break
    sleep 1
  done
}

_write_claude_md() {
  local workdir="$1"
  cat > "$workdir/CLAUDE.md" << 'CEOF'
<!-- dgc-policy-v3 -->
# Dual-Graph Context Policy

This project uses a local dual-graph MCP server for efficient context retrieval.

## BENCH MODE — CRITICAL RULES
- Do NOT use AskUserQuestion, EnterPlanMode, or any interactive tool.
- Do NOT ask clarifying questions. Ever.
- Proceed immediately with the most sensible defaults and build/implement directly.

## MANDATORY: Always follow this order

1. **Call `graph_continue` first** — before any file exploration, grep, or code reading.
2. **If `graph_continue` returns `needs_project=true`**: call `graph_scan` with pwd. Do NOT ask.
3. **Read `recommended_files`** using `graph_read`.
4. **Check `confidence` and obey the caps strictly:**
   - `confidence=high` → Stop. Do NOT grep or explore further.
   - `confidence=medium` → at most `max_supplementary_greps` fallback_rg + `max_supplementary_files` graph_read.
   - `confidence=low`   → at most `max_supplementary_greps` fallback_rg + `max_supplementary_files` graph_read.

## Rules
- Do NOT use rg/grep/bash before graph_continue.
- Do NOT do broad exploration at any confidence level.
- After edits, call graph_register_edit with changed files.
CEOF
}

_quality_report() {
  local with_dir="$1" without_dir="$2"
  "$PYTHON" - "$with_dir" "$without_dir" << 'PYEOF'
import sys, os
from pathlib import Path

def count_project(root):
    skip = {'.dual-graph', 'node_modules', '__pycache__', '.git', 'dist', 'build', '.next'}
    code_ext = {'.py','.ts','.tsx','.js','.jsx','.swift','.go','.css','.html','.sql'}
    files = lines = 0
    by_ext = {}
    for p in Path(root).rglob('*'):
        if any(s in p.parts for s in skip): continue
        if not p.is_file(): continue
        files += 1
        if p.suffix in code_ext:
            try:
                c = p.read_text(errors='ignore').splitlines()
                l = len([x for x in c if x.strip()])
                lines += l
                by_ext[p.suffix] = by_ext.get(p.suffix, 0) + l
            except Exception:
                pass
    return files, lines, by_ext

with_dir, without_dir = sys.argv[1], sys.argv[2]
wf, wl, we = count_project(with_dir)
nf, nl, ne = count_project(without_dir)

print()
print("╔══════════════════════════════════════════════════════════╗")
print("║                  QUALITY COMPARISON                     ║")
print("╠══════════════════════╦═══════════════╦═══════════════════╣")
print("║ Metric               ║  With graph   ║  Without graph    ║")
print("╠══════════════════════╬═══════════════╬═══════════════════╣")
print(f"║ Total files          ║ {wf:>13} ║ {nf:>17} ║")
print(f"║ Lines of code        ║ {wl:>13,} ║ {nl:>17,} ║")
print("╠══════════════════════╩═══════════════╩═══════════════════╣")
all_ext = sorted(set(list(we.keys()) + list(ne.keys())))
if all_ext:
    print("║ By file type:                                            ║")
    for ext in all_ext:
        print(f"║   {ext:<8}  with: {we.get(ext,0):>6} lines   without: {ne.get(ext,0):>6} lines      ║")
print("╚══════════════════════════════════════════════════════════╝")
print()

# Show top-level file tree for both
def tree(root, depth=2):
    skip = {'.dual-graph','node_modules','__pycache__','.git','dist','build','.next','CLAUDE.md'}
    result = []
    for item in sorted(Path(root).iterdir()):
        if item.name in skip: continue
        result.append(f"  {'📁' if item.is_dir() else '📄'} {item.name}")
        if item.is_dir() and depth > 1:
            for sub in sorted(item.iterdir())[:6]:
                if sub.name not in skip:
                    result.append(f"    {'📁' if sub.is_dir() else '📄'} {sub.name}")
    return '\n'.join(result[:30])

print("WITH graph structure:")
print(tree(with_dir))
print()
print("WITHOUT graph structure:")
print(tree(without_dir))
print()
PYEOF
}

_log_run() {
  echo "{\"ts\":\"$1\",\"project\":\"$2\",\"mode\":\"$3\",\"prompt\":\"$4\",\"tokens_with\":$5,\"tokens_without\":$6,\"dur_with\":$7,\"dur_without\":$8}" >> "$BENCH_LOG"
}

# ── Save session mode ─────────────────────────────────────────────────────────
# Usage: dgc-bench --save /path/to/project "label"
# Run this after finishing a claude session to log its tokens + prompts.
if [[ "${1:-}" == "--save" ]]; then
  if [[ $# -lt 3 ]]; then
    echo "Usage: dgc-bench --save /path/to/project \"label\""
    exit 1
  fi
  PROJECT="$(cd "$2" && pwd)"
  LABEL="$3"
  "$PYTHON" - "$PROJECT" "$LABEL" "$BENCH_LOG" << 'PYEOF'
import sys, json, datetime
from pathlib import Path

project, label, bench_log = sys.argv[1], sys.argv[2], sys.argv[3]
encoded = project.replace('/', '-').replace(' ', '-')
sessions_dir = Path.home() / '.claude' / 'projects' / encoded
if not sessions_dir.exists():
    # Case-insensitive fallback (macOS paths may differ in case)
    base = Path.home() / '.claude' / 'projects'
    match = next((d for d in base.iterdir() if d.name.lower() == encoded.lower()), None)
    if match:
        sessions_dir = match
    else:
        print(f"  No session data found for: {project}")
        print(f"  Expected: {sessions_dir}")
        exit(1)
files = sorted(sessions_dir.glob('*.jsonl'), key=lambda f: f.stat().st_mtime)
if not files:
    print("  No session files found."); exit(1)

inp = out = 0
prompts = []
for line in open(files[-1]):
    try:
        obj = json.loads(line.strip())
        role = (obj.get('message') or {}).get('role', '')
        if role == 'user':
            content = (obj.get('message') or {}).get('content', '')
            if isinstance(content, str) and content.strip():
                prompts.append(content.strip()[:120])
            elif isinstance(content, list):
                for b in content:
                    if isinstance(b, dict) and b.get('type') == 'text':
                        t = b.get('text', '').strip()
                        if t: prompts.append(t[:120])
        for u in [obj.get('usage'), (obj.get('message') or {}).get('usage')]:
            if isinstance(u, dict):
                inp = max(inp, u.get('input_tokens', 0) or 0)
                out = max(out, u.get('output_tokens', 0) or 0)
        inp = max(inp, obj.get('total_input_tokens', 0) or 0)
        out = max(out, obj.get('total_output_tokens', 0) or 0)
    except: pass

total = inp + out
print()
print(f"  Label   : {label}")
print(f"  Project : {project}")
print(f"  Tokens  : {total:,}  (input: {inp:,} + output: {out:,})")
if prompts:
    print(f"  Prompts : {len(prompts)}")
    for i, p in enumerate(prompts[:6], 1):
        print(f"    {i}. {p}")

ts = datetime.datetime.utcnow().strftime('%Y-%m-%dT%H:%M:%SZ')
with open(bench_log, 'a') as f:
    f.write(json.dumps({
        "ts": ts, "label": label, "project": project,
        "mode": "session", "tokens": total,
        "inp": inp, "out": out, "prompts": prompts
    }) + '\n')
print(f"\n  Saved to: {bench_log}")
print(f"  Run 'dgc-bench --compare with-graph without-graph' to compare.")
PYEOF
  exit 0
fi

# ── Compare two saved sessions ────────────────────────────────────────────────
# Usage: dgc-bench --compare "label-a" "label-b"
if [[ "${1:-}" == "--compare" ]]; then
  LABEL_A="${2:-with-graph}"
  LABEL_B="${3:-without-graph}"
  [[ ! -f "$BENCH_LOG" ]] && echo "No sessions saved yet. Run dgc-bench --save first." && exit 0
  "$PYTHON" - "$BENCH_LOG" "$LABEL_A" "$LABEL_B" << 'PYEOF'
import sys, json
bench_log, la, lb = sys.argv[1], sys.argv[2], sys.argv[3]
sessions = {}
for line in open(bench_log):
    try:
        obj = json.loads(line.strip())
        if obj.get('mode') == 'session':
            sessions[obj['label']] = obj
    except: pass
a = sessions.get(la)
b = sessions.get(lb)
if not a or not b:
    have = list(sessions.keys())
    print(f"Missing sessions. Have: {have}")
    print(f"Save them first with: dgc-bench --save /path label")
    exit(1)
ta, tb = a['tokens'], b['tokens']
saved = tb - ta
pct = saved/tb*100 if tb else 0
print()
print("╔═══════════════════════════════════════════════════════════╗")
print("║                  SESSION COMPARISON                      ║")
print("╠═══════════════════════════════════════════════════════════╣")
print(f"║  {la:<24}: {ta:>10,} tokens              ║")
print(f"║  {lb:<24}: {tb:>10,} tokens              ║")
print("╠═══════════════════════════════════════════════════════════╣")
print(f"║  Tokens saved         : {saved:>10,}                    ║")
print(f"║  Reduction            : {pct:>10.1f}%                    ║")
cost_a = ta * 9 / 1_000_000
cost_b = tb * 9 / 1_000_000
print("╠═══════════════════════════════════════════════════════════╣")
print(f"║  Est. cost {la:<14}: ${cost_a:>8.4f}                    ║")
print(f"║  Est. cost {lb:<14}: ${cost_b:>8.4f}                    ║")
print(f"║  Money saved          : ${cost_b-cost_a:>8.4f}                    ║")
print("╠═══════════════════════════════════════════════════════════╣")
pa, pb = a.get('prompts',[]), b.get('prompts',[])
print(f"║  Prompts (with)       : {len(pa):<35}║")
for i,p in enumerate(pa[:4],1): print(f"║    {i}. {p[:52]:<52} ║")
print(f"║  Prompts (without)    : {len(pb):<35}║")
for i,p in enumerate(pb[:4],1): print(f"║    {i}. {p[:52]:<52} ║")
print("╚═══════════════════════════════════════════════════════════╝")
print()
PYEOF
  exit 0
fi

# ── Report mode ───────────────────────────────────────────────────────────────
if [[ "${1:-}" == "--report" ]]; then
  [[ ! -f "$BENCH_LOG" ]] && echo "No data yet. Run dgc-bench first." && exit 0
  "$PYTHON" - "$BENCH_LOG" << 'PYEOF'
import sys, json

runs = []
for line in open(sys.argv[1]):
    try: runs.append(json.loads(line.strip()))
    except: pass

if not runs:
    print("No data.")
    sys.exit(0)

tw = sum(r["tokens_with"] for r in runs)
tn = sum(r["tokens_without"] for r in runs)
saved = tn - tw
pct = saved / tn * 100 if tn > 0 else 0

print()
print("╔══════════════════════════════════════════════════════╗")
print("║            DUAL-GRAPH CUMULATIVE REPORT              ║")
print("╠══════════════════════════════════════════════════════╣")
print(f"║  Tasks completed      : {len(runs):<28}║")
print("╠══════════════════════════════════════════════════════╣")
print(f"║  Tokens WITH graph    : {tw:>12,}               ║")
print(f"║  Tokens WITHOUT graph : {tn:>12,}               ║")
print(f"║  Tokens SAVED         : {saved:>12,}               ║")
print(f"║  Reduction            : {pct:>11.1f}%               ║")
print("╠══════════════════════════════════════════════════════╣")
cost_w = tw * 9 / 1_000_000
cost_n = tn * 9 / 1_000_000
print(f"║  Est. cost with graph : ${cost_w:>10.4f}               ║")
print(f"║  Est. cost without    : ${cost_n:>10.4f}               ║")
print(f"║  Est. money saved     : ${cost_n-cost_w:>10.4f}               ║")
print("╚══════════════════════════════════════════════════════╝")
print()
print(f"{'#':<3} {'Tokens W':>9} {'Tokens N':>10} {'Saved%':>7}  Prompt")
print("─" * 72)
for i, r in enumerate(runs, 1):
    tw_r = r["tokens_with"]
    tn_r = r["tokens_without"]
    p_r  = (tn_r - tw_r) / tn_r * 100 if tn_r > 0 else 0
    prompt = r.get("prompt","")[:40]
    print(f"{i:<3} {tw_r:>9,} {tn_r:>10,} {p_r:>6.1f}%  {prompt}")
print()
PYEOF
  exit 0
fi

# ── Live mode ─────────────────────────────────────────────────────────────────
if [[ "${1:-}" == "--live" ]]; then
  if [[ $# -lt 2 ]]; then
    echo "Usage: dgc-bench --live /path/to/workspace [--interactive]"
    exit 1
  fi
  INTERACTIVE=false
  [[ "${3:-}" == "--interactive" || "${4:-}" == "--interactive" ]] && INTERACTIVE=true
  WORKSPACE="$(mkdir -p "$2" && cd "$2" && pwd)"
  WITH_DIR="$WORKSPACE/with-graph"
  WITHOUT_DIR="$WORKSPACE/without-graph"
  WITH_DATA="$WITH_DIR/.dual-graph"
  SESSION_LOG="$WORKSPACE/bench_session.jsonl"
  TS_SESSION="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

  mkdir -p "$WITH_DIR" "$WITHOUT_DIR"

  # Init git in both
  [[ ! -d "$WITH_DIR/.git" ]]    && git -C "$WITH_DIR" init -q
  [[ ! -d "$WITHOUT_DIR/.git" ]] && git -C "$WITHOUT_DIR" init -q

  echo ""
  echo "╔══════════════════════════════════════════════════════════╗"
  echo "║           dgc-bench --live  INTERACTIVE MODE            ║"
  echo "╠══════════════════════════════════════════════════════════╣"
  echo "║  WITH graph    → $WITH_DIR"
  echo "║  WITHOUT graph → $WITHOUT_DIR"
  echo "╠══════════════════════════════════════════════════════════╣"
  if $INTERACTIVE; then
  echo "║  Mode: INTERACTIVE — you run both sessions yourself.    ║"
  else
  echo "║  Mode: HEADLESS — both runs are automated.              ║"
  fi
  echo "║  Type a task and press Enter.                           ║"
  echo "║  Type 'done' to finish and see full report.             ║"
  echo "║  Type 'report' to see running totals.                   ║"
  echo "╚══════════════════════════════════════════════════════════╝"
  echo ""

  TOTAL_WITH=0
  TOTAL_WITHOUT=0
  TASK_NUM=0
  MCP_PID=""

  # Cleanup on exit
  trap '[[ -n "$MCP_PID" ]] && kill $MCP_PID 2>/dev/null; claude mcp remove dual-graph 2>/dev/null || true' EXIT

  while true; do
    printf "\n[bench] Prompt #$((TASK_NUM+1)) > "
    read -r PROMPT || break
    [[ -z "$PROMPT" ]] && continue

    if [[ "$PROMPT" == "done" ]]; then
      break
    fi

    if [[ "$PROMPT" == "report" ]]; then
      "$PYTHON" - "$SESSION_LOG" << 'PYEOF'
import sys, json
runs = []
for line in open(sys.argv[1]):
    try: runs.append(json.loads(line.strip()))
    except: pass
tw = sum(r["tw"] for r in runs)
tn = sum(r["tn"] for r in runs)
saved = tn - tw
pct = saved/tn*100 if tn else 0
print(f"\n  Running totals — {len(runs)} tasks")
print(f"  WITH graph    : {tw:,} tokens")
print(f"  WITHOUT graph : {tn:,} tokens")
print(f"  Saved so far  : {saved:,} tokens ({pct:.1f}%)\n")
PYEOF
      continue
    fi

    TASK_NUM=$((TASK_NUM + 1))
    TS="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

    # ── RUN 1: WITH graph ─────────────────────────────────────────────────────
    echo ""
    echo "  [1/2] Running WITH dual-graph..."
    _rebuild_graph "$WITH_DIR" "$WITH_DATA"
    _start_mcp_server "$WITH_DATA" "$WITH_DIR"
    _write_claude_md "$WITH_DIR"
    claude mcp remove dual-graph 2>/dev/null || true
    claude mcp add --transport http dual-graph "http://localhost:$MCP_PORT/mcp" 2>/dev/null

    T1=$(date +%s)
    if $INTERACTIVE; then
      echo "  Task: $PROMPT"
      _run_interactive "$WITH_DIR" "[1/2] WITH dual-graph — run this task in claude"
    else
      echo "  ┌── with-graph output ─────────────────────────"
      _run_headless "$WITH_DIR" "$PROMPT"
      echo "  └──────────────────────────────────────────────"
    fi
    T2=$(date +%s)
    DUR_WITH=$((T2 - T1))
    WITH_TOK=$_LAST_TOKENS
    echo "  ✓ WITH graph    : ${WITH_TOK} tokens  (${DUR_WITH}s)"
    if [[ "$WITH_TOK" -eq 0 && -s "$_BENCH_STDERR" ]]; then
      echo "  [debug] claude stderr: $(head -3 "$_BENCH_STDERR")" >&2
    fi

    # ── RUN 2: WITHOUT graph ──────────────────────────────────────────────────
    echo "  [2/2] Running WITHOUT dual-graph..."
    claude mcp remove dual-graph 2>/dev/null || true
    # Kill MCP server so without-graph truly has no graph; wait to suppress bash job notification
    [[ -n "$MCP_PID" ]] && { kill $MCP_PID 2>/dev/null; wait $MCP_PID 2>/dev/null; } || true
    lsof -ti:$MCP_PORT 2>/dev/null | xargs kill -9 2>/dev/null || true
    # Write no-questions CLAUDE.md for without-graph run
    cat > "$WITHOUT_DIR/CLAUDE.md" << 'NOMD'
# Bench Mode
Do NOT use AskUserQuestion, EnterPlanMode, or any interactive tool.
Do NOT ask clarifying questions. Proceed immediately with sensible defaults and build directly.
NOMD

    T3=$(date +%s)
    if $INTERACTIVE; then
      echo "  Task: $PROMPT"
      _run_interactive "$WITHOUT_DIR" "[2/2] WITHOUT dual-graph — run the same task"
    else
      echo "  ┌── without-graph output ──────────────────────"
      _run_headless "$WITHOUT_DIR" "$PROMPT"
      echo "  └──────────────────────────────────────────────"
    fi
    T4=$(date +%s)
    DUR_WITHOUT=$((T4 - T3))
    WITHOUT_TOK=$_LAST_TOKENS
    echo "  ✓ WITHOUT graph : ${WITHOUT_TOK} tokens  (${DUR_WITHOUT}s)"
    if [[ "$WITHOUT_TOK" -eq 0 && -s "$_BENCH_STDERR" ]]; then
      echo "  [debug] claude stderr: $(head -3 "$_BENCH_STDERR")" >&2
    fi

    # ── Per-task result ───────────────────────────────────────────────────────
    SAVED=$((WITHOUT_TOK - WITH_TOK))
    PCT=0
    [[ $WITHOUT_TOK -gt 0 ]] && PCT=$(echo "$WITH_TOK $WITHOUT_TOK" | "$PYTHON" -c "import sys; a,b=map(int,sys.stdin.read().split()); print(f'{(b-a)/b*100:.1f}')")

    echo ""
    echo "  ┌─────────────────────────────────────────────┐"
    printf  "  │  WITH graph    : %'10d tokens  %4ds  │\n" "$WITH_TOK" "$DUR_WITH"
    printf  "  │  WITHOUT graph : %'10d tokens  %4ds  │\n" "$WITHOUT_TOK" "$DUR_WITHOUT"
    printf  "  │  Saved         : %'10d tokens  (%s%%)  │\n" "$SAVED" "$PCT"
    echo "  └─────────────────────────────────────────────┘"

    TOTAL_WITH=$((TOTAL_WITH + WITH_TOK))
    TOTAL_WITHOUT=$((TOTAL_WITHOUT + WITHOUT_TOK))

    # Log to session file
    echo "{\"task\":$TASK_NUM,\"ts\":\"$TS\",\"prompt\":\"$PROMPT\",\"tw\":$WITH_TOK,\"tn\":$WITHOUT_TOK,\"dur_w\":$DUR_WITH,\"dur_n\":$DUR_WITHOUT}" >> "$SESSION_LOG"
    # Log to global bench log
    _log_run "$TS" "$WORKSPACE" "live" "$PROMPT" "$WITH_TOK" "$WITHOUT_TOK" "$DUR_WITH" "$DUR_WITHOUT"
  done

  # ── Final report ─────────────────────────────────────────────────────────
  echo ""
  echo "════════════════════════════════════════════════════════════"
  echo "                   SESSION COMPLETE"
  echo "════════════════════════════════════════════════════════════"

  TOTAL_SAVED=$((TOTAL_WITHOUT - TOTAL_WITH))
  TOTAL_PCT=0
  [[ $TOTAL_WITHOUT -gt 0 ]] && TOTAL_PCT=$(echo "$TOTAL_WITH $TOTAL_WITHOUT" | "$PYTHON" -c "import sys; a,b=map(int,sys.stdin.read().split()); print(f'{(b-a)/b*100:.1f}')")

  echo ""
  echo "╔══════════════════════════════════════════════════════╗"
  echo "║              FINAL TOKEN COMPARISON                  ║"
  echo "╠══════════════════════════════════════════════════════╣"
  printf "║  Tasks completed      : %-28s║\n" "$TASK_NUM"
  printf "║  Tokens WITH graph    : %'12d               ║\n" "$TOTAL_WITH"
  printf "║  Tokens WITHOUT graph : %'12d               ║\n" "$TOTAL_WITHOUT"
  printf "║  Total tokens SAVED   : %'12d               ║\n" "$TOTAL_SAVED"
  printf "║  Overall reduction    : %11s%%               ║\n" "$TOTAL_PCT"
  echo "╚══════════════════════════════════════════════════════╝"

  echo ""
  echo "Generating quality comparison..."
  _quality_report "$WITH_DIR" "$WITHOUT_DIR"

  echo "  Session log : $SESSION_LOG"
  echo "  with-graph  : $WITH_DIR"
  echo "  without     : $WITHOUT_DIR"
  echo ""
  exit 0
fi

# ── Single task mode ──────────────────────────────────────────────────────────
if [[ $# -lt 2 ]]; then
  echo "Usage:"
  echo "  dgc-bench --live /path/to/workspace          # interactive dual-build"
  echo "  dgc-bench /path/to/project \"prompt\"          # single task with graph"
  echo "  dgc-bench --report                           # cumulative analytics"
  exit 1
fi

PROJECT="$(cd "$1" && pwd)"
PROMPT="$2"
DATA_DIR="$PROJECT/.dual-graph"
TS="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

echo ""
echo "[bench] Project : $PROJECT"
echo "[bench] Prompt  : $PROMPT"

mkdir -p "$DATA_DIR"
_rebuild_graph "$PROJECT" "$DATA_DIR"
_start_mcp_server "$DATA_DIR" "$PROJECT"

claude mcp remove dual-graph 2>/dev/null || true
claude mcp add --transport http dual-graph "http://localhost:$MCP_PORT/mcp" 2>/dev/null

T1=$(date +%s)
_run_headless "$PROJECT" "$PROMPT"
T2=$(date +%s)
DUR=$((T2-T1))
TOKENS=$_LAST_TOKENS

# Estimate without-graph using learned multiplier or default 15x
MULT=$("$PYTHON" - "$BENCH_LOG" 2>/dev/null << 'PYEOF' || echo "15.0"
import sys, json
try:
    runs = [json.loads(l) for l in open(sys.argv[1]) if l.strip()]
    live = [r for r in runs if r.get("mode")=="live" and r["tokens_without"]>0]
    if live:
        mults = [r["tokens_without"]/r["tokens_with"] for r in live if r["tokens_with"]>0]
        print(f"{sum(mults)/len(mults):.2f}")
    else:
        print("15.0")
except: print("15.0")
PYEOF
)

EST_WITHOUT=$(echo "$TOKENS $MULT" | "$PYTHON" -c "import sys; t,m=sys.stdin.read().split(); print(int(float(t)*float(m)))")
SAVED=$((EST_WITHOUT - TOKENS))
PCT=$(echo "$TOKENS $EST_WITHOUT" | "$PYTHON" -c "import sys; a,b=map(int,sys.stdin.read().split()); print(f'{(b-a)/b*100:.1f}')")

echo ""
echo "╔══════════════════════════════════════════════╗"
printf "║  WITH  graph   : %'10d tokens  %4ds  ║\n" "$TOKENS" "$DUR"
printf "║  WITHOUT (est) : %'10d tokens         ║\n" "$EST_WITHOUT"
printf "║  Saved         : %'10d tokens (%s%%)  ║\n" "$SAVED" "$PCT"
echo "╚══════════════════════════════════════════════╝"
echo "  Run 'dgc-bench --report' for cumulative stats."

_log_run "$TS" "$PROJECT" "track" "$PROMPT" "$TOKENS" "$EST_WITHOUT" "$DUR" "0"
